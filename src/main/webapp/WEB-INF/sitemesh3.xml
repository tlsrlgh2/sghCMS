<?xml version="1.0" encoding="UTF-8"?>
<sitemesh>
    <decorator-prefix>/WEB-INF/jsp/layout/</decorator-prefix>
    <!-- Tomcat 11의 forward 응답 커밋을 피해서 decorator 결과를 버퍼에 유지한다. -->
    <dispatch-mode>include</dispatch-mode>

    <!-- 어드민 레이아웃 -->
    <mapping path="/admin/*" decorator="admin/layout.jsp"/>
    <mapping path="/cop/bbs/*" decorator="admin/layout.jsp"/>
    <mapping path="/uss/umt/*" decorator="admin/layout.jsp"/>
    <mapping path="/uss/ion/bnr/*" decorator="admin/layout.jsp"/>
    <mapping path="/uss/ion/pwm/*" decorator="admin/layout.jsp"/>
    <mapping path="/uss/olh/faq/*" decorator="admin/layout.jsp"/>
    <mapping path="/uss/olh/qna/*" decorator="admin/layout.jsp"/>
    <mapping path="/uss/ion/sit/*" decorator="admin/layout.jsp"/>
    <mapping path="/uss/sam/stp/*" decorator="admin/layout.jsp"/>
    <mapping path="/sym/mnu/*" decorator="admin/layout.jsp"/>
    <mapping path="/sym/prm/*" decorator="admin/layout.jsp"/>
    <mapping path="/sym/ccm/*" decorator="admin/layout.jsp"/>
    <mapping path="/sec/*" decorator="admin/layout.jsp"/>
    <mapping path="/uat/uap/*" decorator="admin/layout.jsp"/>
    <mapping path="/sts/*" decorator="admin/layout.jsp"/>
    <mapping path="/sym/log/*" decorator="admin/layout.jsp"/>

    <!-- 사용자 레이아웃 -->
    <mapping path="/user/*"  decorator="user/layout.jsp"/>

    <!-- 레이아웃 제외 경로 (로그인, 에러, Ajax 등) -->
    <mapping path="/uat/uia/*" exclude="true"/>
    <mapping path="/user/login.do"      exclude="true"/>
    <mapping path="/user/loginAction.do" exclude="true"/>
    <mapping path="/user/logout.do"      exclude="true"/>
    <mapping path="/user/checkId.do"     exclude="true"/>
    <mapping path="/cmm/error/*"         exclude="true"/>
</sitemesh>
